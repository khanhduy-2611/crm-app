<%
    const makePageUrl = (targetPage, targetLimit = limit) => {
        const query = [`page=${targetPage}`, `limit=${targetLimit}`];
        if (keyword) query.push(`keyword=${encodeURIComponent(keyword)}`);
        return `/khach-hang?${query.join('&')}`;
    };
    const formatDate = value => value ? new Date(value).toLocaleDateString('vi-VN') : '---';
    const isoDate = value => value ? new Date(value).toISOString().split('T')[0] : '';
    const attr = value => String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
%>

<% function renderVipList(vipList, customer) { %>
    <% if (vipList.length === 0) { %>
        <span class="vip-empty">---</span>
    <% } %>
    <% vipList.forEach(vip => { %>
        <article id="vip-view-<%= vip.id %>"
                 class="vip-card vip-compact-card"
                 data-ngaysinh="<%= isoDate(vip.ngay_sinh) %>"
                 data-vip-id="<%= vip.id %>"
                 data-vip-ho-ten="<%= attr(vip.ho_ten) %>"
                 data-vip-email=""
                 data-vip-so-dien-thoai="<%= attr(vip.so_dien_thoai) %>"
                 data-vip-ghi-chu="<%= attr(vip.ghi_chu) %>"
                 data-vip-khach-hang-id="<%= customer.id %>"
                 data-vip-ten-khach-hang="<%= attr(customer.ten_khach_hang) %>"
                 data-vip-ngay-sinh="<%= isoDate(vip.ngay_sinh) %>"
                 data-vip-ngay-thanh-lap="<%= isoDate(customer.ngay_thanh_lap) %>"
                 data-vip-lich-su-count="<%= vip.lich_su_count || 0 %>">
            <button type="button" class="vip-card-main" onclick="openVipDetail(<%= vip.id %>)">
                <span class="vip-card-name"><%= vip.ho_ten %></span>
                <span class="vip-card-role role-color-<%= vip.nhom_mau_chuc_vu || 'khac' %>">
                    <%= vip.chuc_vu || 'Chưa có chức vụ' %>
                </span>
                <span class="vip-card-detail"><%= vip.so_dien_thoai || '---' %></span>
                <span class="birthday-badge" style="display:none;"></span>
            </button>
            <div class="vip-card-actions">
                <button type="button" class="vip-mini-action"
                        onclick="openVipHistory(<%= vip.id %>, <%= customer.id %>)"
                        title="Lịch sử chăm sóc">
                    <i class="fa-regular fa-clock"></i>
                    <% if (Number(vip.lich_su_count || 0) > 0) { %>
                        <span class="acc-count"><%= vip.lich_su_count %></span>
                    <% } %>
                </button>
                <button type="button" class="vip-mini-action btn-edit-vip-card"
                        data-id="<%= vip.id %>" title="Sửa VIP">
                    <i class="fa-solid fa-pen"></i>
                </button>
                <button type="button" class="vip-mini-action danger btn-xoa-vip"
                        data-id="<%= vip.id %>" data-ten="<%= attr(vip.ho_ten) %>" title="Xóa VIP">
                    <i class="fa-regular fa-trash-can"></i>
                </button>
            </div>
        </article>
    <% }) %>
<% } %>

<div class="table-responsive vip-company-table-wrap">
    <table class="table align-middle mb-0 vip-company-table" id="tableVip">
        <thead>
            <tr>
                <th>Mã số</th>
                <th>Tên khách hàng / Cơ quan</th>
                <th>Thành lập</th>
                <th>Lãnh đạo</th>
                <th>Kế toán</th>
                <th>Khác</th>
                <th>Cán bộ chăm sóc</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% if (listKhachHangGrouped.length === 0) { %>
                <tr>
                    <td colspan="8" class="text-center py-5 text-muted">
                        Không tìm thấy khách hàng hoặc nhân sự VIP phù hợp.
                    </td>
                </tr>
            <% } %>

            <% listKhachHangGrouped.forEach(kh => {
                const lanhDao = kh.ds_vip.filter(vip => vip.nhom_hien_thi === 'lanh_dao');
                const keToan = kh.ds_vip.filter(vip => vip.nhom_hien_thi === 'ke_toan');
                const khac = kh.ds_vip.filter(vip => vip.nhom_hien_thi === 'khac');
            %>
                <tr id="customer-view-<%= kh.id %>"
                    class="vip-company-row"
                    data-customer-id="<%= kh.id %>"
                    data-customer-name="<%= attr(kh.ten_khach_hang) %>">
                    <td class="customer-code"><%= kh.ma_kh || `KH${String(kh.id).padStart(3, '0')}` %></td>
                    <td class="customer-main-cell">
                        <div class="customer-name"><%= kh.ten_khach_hang %></div>
                    </td>
                    <td class="customer-date"><%= formatDate(kh.ngay_thanh_lap) %></td>
                    <td class="vip-group-cell"><% renderVipList(lanhDao, kh); %></td>
                    <td class="vip-group-cell"><% renderVipList(keToan, kh); %></td>
                    <td class="vip-group-cell"><% renderVipList(khac, kh); %></td>
                    <td class="officer-cell">
                        <% if (!kh.can_bo_cham_soc) { %>
                            <span class="vip-empty">---</span>
                        <% } else { %>
                            <div class="officer-item">
                                <strong><%= kh.can_bo_cham_soc %></strong>
                                <span><%= kh.phong_ban || '---' %></span>
                            </div>
                        <% } %>
                    </td>
                    <td class="text-center customer-actions">
                        <button type="button" class="customer-action btn-edit-customer"
                                data-id="<%= kh.id %>" title="Sửa doanh nghiệp">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button type="button" class="customer-action danger btn-xoa-kh"
                                data-id="<%= kh.id %>" data-ten="<%= attr(kh.ten_khach_hang) %>" title="Xóa doanh nghiệp">
                            <i class="fa-regular fa-trash-can"></i>
                        </button>
                    </td>
                </tr>

                <tr id="customer-edit-<%= kh.id %>" class="customer-edit-row" style="display:none;">
                    <td colspan="8">
                        <form id="form-kh-<%= kh.id %>" action="/khach-hang/update" method="POST" class="row g-2 align-items-end">
                            <input type="hidden" name="id" value="<%= kh.id %>">
                            <div class="col-md-7">
                                <label class="form-label">Tên khách hàng / Cơ quan</label>
                                <input type="text" class="form-control form-control-sm" name="ten_khach_hang"
                                       value="<%= attr(kh.ten_khach_hang) %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Ngày thành lập</label>
                                <input type="date" class="form-control form-control-sm" name="ngay_thanh_lap"
                                       value="<%= isoDate(kh.ngay_thanh_lap) %>">
                            </div>
                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-success flex-fill">Lưu</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary btn-cancel-customer"
                                        data-id="<%= kh.id %>">Hủy</button>
                            </div>
                        </form>
                    </td>
                </tr>

                <tr id="customer-history-<%= kh.id %>" class="customer-detail-row" style="display:none;">
                    <td colspan="8">
                        <div id="customer-history-content-<%= kh.id %>" class="customer-history-content"></div>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%
    const rangeStart = totalFilteredKhachHang === 0 ? 0 : (page - 1) * limit + 1;
    const rangeEnd = Math.min(page * limit, totalFilteredKhachHang);
    const firstPage = Math.max(1, Math.min(page - 2, totalPages - 4));
    const lastPage = Math.min(totalPages, firstPage + 4);
%>
<div class="pagination-bar">
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <span class="pagination-info">
            Hiển thị <strong><%= rangeStart %>-<%= rangeEnd %></strong>
            trên tổng <strong><%= totalFilteredKhachHang %></strong> khách hàng
        </span>
        <select class="form-select form-select-sm pagination-limit" id="paginationLimit">
            <option value="20" <%= limit === 20 ? 'selected' : '' %>>20 dòng</option>
            <option value="50" <%= limit === 50 ? 'selected' : '' %>>50 dòng</option>
        </select>
    </div>
    <div class="pagination-controls">
        <a class="pagination-link <%= page <= 1 ? 'disabled' : '' %>"
           href="<%= page <= 1 ? '#' : makePageUrl(page - 1) %>" aria-label="Trang trước">
            <i class="fa-solid fa-chevron-left"></i>
        </a>
        <% for (let pageNumber = firstPage; pageNumber <= lastPage; pageNumber++) { %>
            <a class="pagination-link <%= pageNumber === page ? 'active' : '' %>"
               href="<%= makePageUrl(pageNumber) %>"><%= pageNumber %></a>
        <% } %>
        <a class="pagination-link <%= page >= totalPages ? 'disabled' : '' %>"
           href="<%= page >= totalPages ? '#' : makePageUrl(page + 1) %>" aria-label="Trang sau">
            <i class="fa-solid fa-chevron-right"></i>
        </a>
    </div>
</div>
