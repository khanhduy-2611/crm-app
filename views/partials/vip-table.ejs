                <%
                    const makePageUrl = (targetPage, targetLimit = limit) => {
                        const query = [`page=${targetPage}`, `limit=${targetLimit}`];
                        if (keyword) query.push(`keyword=${encodeURIComponent(keyword)}`);
                        if (chucVu && chucVu !== 'all') query.push(`chucVu=${encodeURIComponent(chucVu)}`);
                        return `/khach-hang?${query.join('&')}`;
                    };
                %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="tableVip">
                        <thead class="sticky-top">
                            <tr class="table-success">
                                <th style="width:30px"></th>
                                <th>Họ Tên</th>
                                <th>Thuộc Đơn Vị</th>
                                <th>Chức Vụ</th>
                                <th>Ngày Sinh</th>
                                <th>Số ĐT</th>
                                <th>Ghi Chú</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (listVip.length === 0) { %>
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">
                                        Không tìm thấy nhân sự VIP phù hợp.
                                    </td>
                                </tr>
                            <% } %>
                            <% listVip.forEach(vip => {
                                const ngaySV = vip.ngay_sinh instanceof Date
                                    ? `${vip.ngay_sinh.getFullYear()}-${String(vip.ngay_sinh.getMonth()+1).padStart(2,'0')}-${String(vip.ngay_sinh.getDate()).padStart(2,'0')}`
                                    : vip.ngay_sinh;
                                const lichSuCount = Number(vip.lich_su_count || 0);
                                const lastCareDate = vip.last_care_date;
                                const lastCareStr = lastCareDate
                                    ? (lastCareDate instanceof Date
                                        ? `${lastCareDate.getFullYear()}-${String(lastCareDate.getMonth()+1).padStart(2,'0')}-${String(lastCareDate.getDate()).padStart(2,'0')}`
                                        : String(lastCareDate).split('T')[0])
                                    : '';
                            %>
                                <!-- Dòng xem VIP -->
                                <tr id="vip-view-<%= vip.id %>" class="vip-item-row"
                                    data-ngaysinh="<%= ngaySV || '' %>"
                                    data-lastcare="<%= lastCareStr %>"
                                    data-chucvu="<%= (vip.chuc_vu || '').toLowerCase() %>"
                                    data-chucvuid="<%= vip.chuc_vu_id || '' %>"
                                    data-vip-id="<%= vip.id %>"
                                    data-vip-ho-ten="<%= vip.ho_ten %>"
                                    data-vip-email="<%= vip.email || '' %>"
                                    data-vip-so-dien-thoai="<%= vip.so_dien_thoai || '' %>"
                                    data-vip-ghi-chu="<%= (vip.ghi_chu || '').replace(/"/g, '&quot;') %>"
                                    data-vip-khach-hang-id="<%= vip.khach_hang_id %>"
                                    data-vip-ten-khach-hang="<%= vip.ten_khach_hang %>"
                                    data-vip-ngay-sinh="<%= vip.ngay_sinh ? new Date(vip.ngay_sinh).toISOString().split('T')[0] : '' %>"
                                    data-vip-ngay-thanh-lap="<%= vip.ngay_thanh_lap ? new Date(vip.ngay_thanh_lap).toISOString().split('T')[0] : '' %>"
                                    data-vip-lich-su-count="<%= lichSuCount %>">
                                    <td>
                                        <button class="btn-accordion" onclick="toggleAccordion(<%= vip.id %>)" id="btn-acc-<%= vip.id %>" title="Xem lịch sử chăm sóc">
                                            <i class="fa-solid fa-chevron-right" id="icon-acc-<%= vip.id %>"></i>
                                            <% if (lichSuCount > 0) { %>
                                                <span class="acc-count"><%= lichSuCount %></span>
                                            <% } %>
                                        </button>
                                    </td>
                                    <td class="fw-bold text-success vip-search-field" style="cursor:pointer;" onclick="openVipDetail(<%= vip.id %>)">
                                        <%= vip.ho_ten %>
                                        <div class="care-progress-wrap">
                                            <div class="care-progress-bar" data-lastcare="<%= lastCareStr %>"></div>
                                        </div>
                                        <div class="care-progress-label"></div>
                                    </td>
                                    <td class="small vip-search-field"><%= vip.ten_khach_hang %></td>
                                    <td><span class="badge bg-secondary"><%= vip.chuc_vu || '---' %></span></td>
                                    <td>
                                        <span class="ngay-sinh-display"><%= vip.ngay_sinh ? new Date(vip.ngay_sinh).toLocaleDateString('vi-VN') : '---' %></span>
                                        <span class="birthday-badge" style="display:none;"></span>
                                    </td>
                                    <td class="text-primary vip-search-field"><%= vip.so_dien_thoai %></td>
                                    <td class="small text-muted fst-italic"><%= vip.ghi_chu || '---' %></td>
                                    <td class="text-center" style="white-space:nowrap;">
                                        <button class="btn btn-sm btn-outline-warning me-1 btn-sua-vip" data-id="<%= vip.id %>">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-xoa-vip"
                                                data-id="<%= vip.id %>"
                                                data-ten="<%= vip.ho_ten %>">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </td>
                                </tr>

                                <!-- Dòng sửa VIP -->
                                <tr id="vip-edit-<%= vip.id %>" style="display:none;" class="table-light">
                                    <td></td>
                                    <td colspan="6">
                                        <form id="form-vip-<%= vip.id %>" action="/khach-hang/vip/update" method="POST">
                                            <input type="hidden" name="id" value="<%= vip.id %>">
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input type="text" class="form-control form-control-sm" name="ho_ten"
                                                           value="<%= vip.ho_ten %>" required placeholder="Họ tên">
                                                </div>
                                                <div class="col-md-4">
                                                    <select class="form-select form-select-sm" name="khach_hang_id" required>
                                                        <% listKhachHang.forEach(kh => { %>
                                                            <option value="<%= kh.id %>" <%= kh.id == vip.khach_hang_id ? 'selected' : '' %>>
                                                                <%= kh.ten_khach_hang %>
                                                            </option>
                                                        <% }) %>
                                                    </select>
                                                </div>
                                                <div class="col-md-4">
                                                    <select class="form-select form-select-sm" name="chuc_vu_id" required>
                                                        <% listChucVu.forEach(cv => { %>
                                                            <option value="<%= cv.id %>" <%= cv.id == vip.chuc_vu_id ? 'selected' : '' %>>
                                                                <%= cv.ten_chuc_vu %>
                                                            </option>
                                                        <% }) %>
                                                    </select>
                                                </div>
                                                <div class="col-md-4">
                                                    <input type="date" class="form-control form-control-sm" name="ngay_sinh"
                                                           value="<%= ngaySV %>" required>
                                                </div>
                                                <div class="col-md-4">
                                                    <input type="text" class="form-control form-control-sm" name="so_dien_thoai"
                                                           value="<%= vip.so_dien_thoai %>" maxlength="10" required
                                                           oninput="kiemTraSoDienThoai(this)">
                                                </div>
                                                <div class="col-md-8">
                                                    <textarea class="form-control form-control-sm" name="ghi_chu"
                                                            rows="2" placeholder="Ghi chú cá nhân (sở thích, quà đã tặng...)"
                                                    ><%= vip.ghi_chu || '' %></textarea>
                                                </div>
                                            </div>
                                        </form>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-success me-1 btn-luu-vip" data-id="<%= vip.id %>">
                                            <i class="fa-solid fa-floppy-disk"></i>
                                        </button>
                                        <button class="btn btn-sm btn-secondary btn-huy-vip" data-id="<%= vip.id %>">✕</button>
                                    </td>
                                </tr>

                                <!-- ACCORDION: LỊCH SỬ CHĂM SÓC -->
                                <tr id="acc-<%= vip.id %>" style="display:none;">
                                    <td colspan="8" style="padding:0;background:var(--surface);">
                                        <div style="padding:12px 16px 16px 40px;border-top:2px dashed rgba(26,138,86,0.2);">

                                            <!-- Header lịch sử -->
                                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                                <span style="font-size:0.72rem;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--accent-dark);">
                                                    <i class="fa-solid fa-clipboard-list me-1"></i>Lịch Sử Chăm Sóc — <%= vip.ho_ten %>
                                                </span>
                                                <button class="btn btn-sm fw-bold text-dark px-3"
                                                        style="background:var(--accent);border:none;border-radius:var(--radius-sm);font-size:0.78rem;"
                                                        onclick="moFormThemLS(<%= vip.id %>)">
                                                    <i class="fa-solid fa-plus me-1"></i>Thêm lịch sử
                                                </button>
                                            </div>

                                            <!-- Form thêm lịch sử (ẩn mặc định) -->
                                            <div id="form-them-ls-<%= vip.id %>" style="display:none;" class="mb-3">
                                                <div class="section-box">
                                                    <form action="/lich-su/add" method="POST">
                                                        <input type="hidden" name="vip_id" value="<%= vip.id %>">
                                                        <div class="row g-2">
                                                            <div class="col-md-2">
                                                                <label class="form-label">Ngày Liên Hệ <span class="text-danger">*</span></label>
                                                                <input type="date" class="form-control form-control-sm" name="ngay_lien_he" required>
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label">Nội Dung <span class="text-danger">*</span></label>
                                                                <input type="text" class="form-control form-control-sm" name="noi_dung" required
                                                                       placeholder="Ví dụ: Gọi điện chúc sinh nhật">
                                                            </div>
                                                            <div class="col-md-3">
                                                                <label class="form-label">Quà Tặng</label>
                                                                <input type="text" class="form-control form-control-sm" name="qua_tang"
                                                                       placeholder="Ví dụ: Hộp bánh kem">
                                                            </div>
                                                            <div class="col-md-3">
                                                                <label class="form-label">Người Phụ Trách <span class="text-danger">*</span></label>
                                                                <input type="text" class="form-control form-control-sm" name="nguoi_phu_trach" required
                                                                       placeholder="Tên người thực hiện">
                                                            </div>
                                                        </div>
                                                        <div class="mt-2 d-flex gap-2">
                                                            <button type="submit" class="btn btn-sm fw-bold px-3 text-dark"
                                                                    style="background:var(--accent);border:none;border-radius:var(--radius-sm);">
                                                                <i class="fa-solid fa-floppy-disk me-1"></i>Lưu
                                                            </button>
                                                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                    onclick="dongFormThemLS(<%= vip.id %>)">Đóng</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <div id="lich-su-content-<%= vip.id %>"
                                                 class="lich-su-lazy-content"
                                                 data-vip-id="<%= vip.id %>"
                                                 data-user-role="admin"
                                                 data-loaded="false">
                                                <div style="text-align:center;padding:16px;color:var(--text-light);font-size:0.82rem;">
                                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>Đang tải lịch sử chăm sóc...
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <%
                    const rangeStart = totalFilteredVip === 0 ? 0 : (page - 1) * limit + 1;
                    const rangeEnd = Math.min(page * limit, totalFilteredVip);
                    const firstPage = Math.max(1, Math.min(page - 2, totalPages - 4));
                    const lastPage = Math.min(totalPages, firstPage + 4);
                %>
                <div class="pagination-bar">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="pagination-info">
                            Hiển thị <strong><%= rangeStart %>–<%= rangeEnd %></strong>
                            trên tổng <strong><%= totalFilteredVip %></strong> bản ghi
                        </span>
                        <select class="form-select form-select-sm pagination-limit" id="paginationLimit">
                            <option value="20" <%= limit === 20 ? 'selected' : '' %>>20 dòng</option>
                            <option value="50" <%= limit === 50 ? 'selected' : '' %>>50 dòng</option>
                        </select>
                    </div>
                    <div class="pagination-controls">
                        <a class="pagination-link <%= page <= 1 ? 'disabled' : '' %>"
                           href="<%= page <= 1 ? '#' : makePageUrl(page - 1) %>" aria-label="Trang trước">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                        <% for (let pageNumber = firstPage; pageNumber <= lastPage; pageNumber++) { %>
                            <a class="pagination-link <%= pageNumber === page ? 'active' : '' %>"
                               href="<%= makePageUrl(pageNumber) %>"><%= pageNumber %></a>
                        <% } %>
                        <a class="pagination-link <%= page >= totalPages ? 'disabled' : '' %>"
                           href="<%= page >= totalPages ? '#' : makePageUrl(page + 1) %>" aria-label="Trang sau">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </div>
                </div>
