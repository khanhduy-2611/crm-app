    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        const overlay = document.getElementById('cmdOverlay');
        if (overlay.classList.contains('open')) {
            closeCmdPalette({target: overlay});
        } else {
            openCmdPalette();
        }
    }
});

