<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Khách hàng & VIP</title>
    <link href="/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/be-vietnam-pro/local.css" rel="stylesheet">
    <link href="/vendor/fontawesome/css/all.min.css" rel="stylesheet">
    <link href="/css/khach-hang.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-expand-lg">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold" href="/">HỆ THỐNG CRM NỘI BỘ</a>
        <div class="navbar-nav">
            <a class="nav-link" href="/"><i class="fa-solid fa-house-chimney me-1"></i>Màn hình chính</a>
            <a class="nav-link active" href="/khach-hang"><i class="fa-solid fa-users me-1"></i>Quản lý Khách Hàng & VIP</a>
        </div>
        <div class="navbar-clock">
            <div class="clock-display">
                <i class="fa-regular fa-clock"></i>
                <div>
                    <div class="clock-time" id="clockTime">--:--:--</div>
                    <div class="clock-date" id="clockDate">--/--/----</div>
                </div>
            </div>
            <% const tongSuKien = suKienHomNay.length + suKienSapToi.length; %>
            <div class="notification-wrap" id="notificationWrap">
                <button type="button"
                        class="notification-bell <%= suKienHomNay.length > 0 ? 'has-today' : '' %>"
                        id="notificationBell"
                        onclick="toggleNotificationPanel(event)"
                        title="Thông báo sinh nhật và ngày thành lập"
                        aria-label="Mở thông báo">
                    <i class="fa-solid fa-bell"></i>
                    <% if (tongSuKien > 0) { %>
                        <span class="notification-count"><%= tongSuKien > 99 ? '99+' : tongSuKien %></span>
                    <% } %>
                </button>
                <div class="notification-panel" id="notificationPanel">
                    <div class="notification-header">
                        <i class="fa-solid fa-bell me-2" style="color:var(--accent-dark);"></i>
                        Thông báo sự kiện
                    </div>
                    <% if (tongSuKien === 0) { %>
                        <div class="notification-empty">
                            <i class="fa-regular fa-bell-slash d-block mb-2" style="font-size:1.5rem;"></i>
                            Không có sinh nhật hoặc ngày thành lập trong 7 ngày tới.
                        </div>
                    <% } %>
                    <% if (suKienHomNay.length > 0) { %>
                        <div class="notification-group-title">Hôm nay</div>
                        <% suKienHomNay.forEach(event => { %>
                            <div class="notification-item today">
                                <div class="notification-item-icon">
                                    <i class="fa-solid <%= event.type === 'vip' ? 'fa-cake-candles' : 'fa-building' %>"></i>
                                </div>
                                <div>
                                    <div class="notification-item-title"><%= event.title %></div>
                                    <div class="notification-item-sub">
                                        <%= event.type === 'vip' ? 'Sinh nhật' : event.subtitle %>
                                        <% if (event.type === 'vip') { %> · <%= event.subtitle %><% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                    <% if (suKienSapToi.length > 0) { %>
                        <div class="notification-group-title">Trong 7 ngày tới</div>
                        <% suKienSapToi.forEach(event => { %>
                            <div class="notification-item">
                                <div class="notification-item-icon">
                                    <i class="fa-solid <%= event.type === 'vip' ? 'fa-cake-candles' : 'fa-building' %>"></i>
                                </div>
                                <div>
                                    <div class="notification-item-title"><%= event.title %></div>
                                    <div class="notification-item-sub">
                                        Còn <strong><%= event.daysLeft %> ngày</strong> ·
                                        <%= event.date.toLocaleDateString('vi-VN') %> ·
                                        <%= event.type === 'vip' ? event.subtitle : event.subtitle %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</nav>

<% if (suKienHomNay.length > 0) { %>
    <div class="celebration-ticker" role="status">
        <div class="celebration-ticker-track">
            <% suKienHomNay.forEach(event => { %>
                <span>
                    <i class="fa-solid fa-star me-2"></i>
                    Chúc mừng <strong><%= event.title %></strong>
                    <%= event.type === 'vip' ? 'có sinh nhật hôm nay' : 'kỷ niệm ngày thành lập hôm nay' %>!
                </span>
                <span aria-hidden="true">🎉 🎂 🎊 ✨</span>
            <% }) %>
        </div>
    </div>
    <div class="celebration-effects" id="celebrationEffects" aria-hidden="true"></div>
<% } %>

<div class="container-fluid px-4">

    <!-- THỐNG KÊ NHANH -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Tổng Doanh Nghiệp</div>
                        <div class="stat-value"><%= thongKe.tongKH %></div>
                    </div>
                    <div class="stat-icon">
                        <i class="fa-solid fa-building"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card accent">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Nhân Sự VIP</div>
                        <div class="stat-value"><%= thongKe.tongVip %></div>
                    </div>
                    <div class="stat-icon">
                        <i class="fa-solid fa-crown"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 d-flex align-items-center justify-content-end gap-2">
            <button type="button" class="btn btn-success fw-bold px-4" id="btnThemKhachHangTop" onclick="moFormAddCustomer()">
                <i class="fa-solid fa-user-plus me-2"></i>Thêm khách hàng
            </button>
            <button class="btn btn-outline-primary fw-bold px-4" onclick="moModalImport()">
                <i class="fa-solid fa-file-import me-2"></i>Import Excel
            </button>
        </div>
    </div>

    <div class="row g-4">

        <!-- ========== BẢNG DỮ LIỆU (FULL WIDTH) ========== -->
        <div id="tableCol" class="col-md-12">

            <!-- BẢNG VIP + ACCORDION LỊCH SỬ -->
            <div class="card border-0 shadow-sm rounded p-3">
                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                    <div>
                        <h5 class="section-title mb-1">
                            <i class="fa-solid fa-building-user"></i>Danh sách khách hàng
                        </h5>
                        <small class="text-muted" style="font-size:0.75rem;">Mỗi khách hàng hoặc cơ quan được hiển thị trên một dòng</small>
                    </div>
                    <input type="text" id="searchVip" class="form-control form-control-sm search-input"
                           style="max-width:520px; width:min(100%, 520px);" placeholder="Tìm theo tên hoặc SĐT... Nhấn Enter để tìm"
                           value="<%= keyword %>">
                </div>
                <%- include('partials/vip-table', {
                    listKhachHangGrouped,
                    listKhachHang,
                    listChucVu,
                    listCanBo,
                    page,
                    limit,
                    totalPages,
                    totalFilteredKhachHang,
                    keyword,
                    chucVu
                }) %>
            </div>

        </div>
    </div>
</div>


<!-- ===== COMMAND PALETTE ===== -->
<div id="cmdOverlay" onclick="closeCmdPalette(event)">
    <div id="cmdBox">
        <input id="cmdInput" type="text"
               placeholder="🔍  Tìm VIP, doanh nghiệp, hoặc gõ lệnh..."
               autocomplete="off"
               oninput="cmdSearch(this.value)"
               onkeydown="cmdKeyNav(event)">
        <div id="cmdResults"></div>
        <div id="cmdFooter">
            <span class="cmd-hint"><kbd>↑</kbd><kbd>↓</kbd> Điều hướng</span>
            <span class="cmd-hint"><kbd>Enter</kbd> Chọn</span>
            <span class="cmd-hint"><kbd>Esc</kbd> Đóng</span>
            <span class="cmd-hint"><kbd>Ctrl</kbd>+<kbd>K</kbd> Mở/Đóng</span>
        </div>
    </div>
</div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/khach-hang.js"></script>

<%- include('partials/modals', { listChucVu, listCanBo }) %>

