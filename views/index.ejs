<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard CRM Agribank</title>
    <link href="/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/be-vietnam-pro/local.css" rel="stylesheet">
    <link href="/vendor/fontawesome/css/all.min.css" rel="stylesheet">
    <link href="/css/dashboard.css" rel="stylesheet">
</head>
<body>
<% const birthdaysToday = birthdays.filter(item => item.days_left === 0); %>
<% const birthdaysUpcoming = birthdays.filter(item => item.days_left > 0); %>
<% const anniversariesToday = anniversaries.filter(item => item.days_left === 0); %>
<% const anniversariesUpcoming = anniversaries.filter(item => item.days_left > 0); %>
<% const eventsToday = [
    ...anniversariesToday.map(item => ({ type: 'company', title: item.ten_khach_hang, subtitle: 'Kỷ niệm ngày thành lập' })),
    ...birthdaysToday.map(item => ({ type: 'vip', title: item.ho_ten, subtitle: item.ten_khach_hang || 'Chưa có doanh nghiệp' }))
]; %>
<% const totalNotifications = birthdays.length + anniversaries.length; %>
<% const dashboardUrl = (nextKhPage, nextVipPage, nextLimit = limit) => `/?khPage=${nextKhPage}&vipPage=${nextVipPage}&limit=${nextLimit}`; %>

<nav class="navbar navbar-expand-lg">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold" href="/">HỆ THỐNG CRM NỘI BỘ</a>
        <div class="navbar-nav">
            <a class="nav-link active" href="/"><i class="fa-solid fa-house-chimney me-1"></i>Màn hình chính</a>
            <a class="nav-link" href="/khach-hang"><i class="fa-solid fa-users me-1"></i>Quản lý Khách Hàng & VIP</a>
        </div>
        <div class="navbar-clock">
            <div class="clock-display">
                <i class="fa-regular fa-clock"></i>
                <div>
                    <div class="clock-time" id="clockTime">--:--:--</div>
                    <div class="clock-date" id="clockDate">--/--/----</div>
                </div>
            </div>
            <div class="notification-wrap" id="notificationWrap">
                <button type="button"
                        class="notification-bell <%= eventsToday.length > 0 ? 'has-today' : '' %>"
                        id="notificationBell"
                        onclick="toggleDashboardNotifications(event)"
                        title="Thông báo sinh nhật và ngày thành lập"
                        aria-label="Mở thông báo">
                    <i class="fa-solid fa-bell"></i>
                    <% if (totalNotifications > 0) { %>
                        <span class="notification-count"><%= totalNotifications > 99 ? '99+' : totalNotifications %></span>
                    <% } %>
                </button>
                <div class="notification-panel" id="notificationPanel">
                    <div class="notification-header"><i class="fa-solid fa-bell me-2"></i>Thông báo sự kiện</div>
                    <% if (totalNotifications === 0) { %>
                        <div class="notification-empty">Không có sinh nhật hoặc ngày thành lập trong 7 ngày tới.</div>
                    <% } %>
                    <% if (eventsToday.length > 0) { %>
                        <div class="notification-group-title">Hôm nay</div>
                        <% eventsToday.forEach(event => { %>
                            <div class="notification-item today">
                                <div class="notification-item-icon">
                                    <i class="fa-solid <%= event.type === 'vip' ? 'fa-cake-candles' : 'fa-building' %>"></i>
                                </div>
                                <div>
                                    <strong><%= event.title %></strong>
                                    <span><%= event.type === 'vip' ? 'Sinh nhật · ' + event.subtitle : event.subtitle %></span>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                    <% if (anniversariesUpcoming.length + birthdaysUpcoming.length > 0) { %>
                        <div class="notification-group-title">Trong 7 ngày tới</div>
                        <% anniversariesUpcoming.forEach(item => { %>
                            <div class="notification-item">
                                <div class="notification-item-icon"><i class="fa-solid fa-building"></i></div>
                                <div><strong><%= item.ten_khach_hang %></strong><span>Còn <%= item.days_left %> ngày · Kỷ niệm ngày thành lập</span></div>
                            </div>
                        <% }) %>
                        <% birthdaysUpcoming.forEach(item => { %>
                            <div class="notification-item">
                                <div class="notification-item-icon"><i class="fa-solid fa-cake-candles"></i></div>
                                <div><strong><%= item.ho_ten %></strong><span>Còn <%= item.days_left %> ngày · <%= item.ten_khach_hang || 'Chưa có doanh nghiệp' %></span></div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</nav>

<% if (eventsToday.length > 0) { %>
    <div class="celebration-ticker" role="status">
        <div class="celebration-ticker-track">
            <% eventsToday.forEach(event => { %>
                <span>
                    <i class="fa-solid fa-star me-2"></i>
                    Chúc mừng <strong><%= event.title %></strong>
                    <%= event.type === 'vip' ? 'có sinh nhật hôm nay' : 'kỷ niệm ngày thành lập hôm nay' %>!
                </span>
            <% }) %>
        </div>
    </div>
    <div class="celebration-effects" id="celebrationEffects" aria-hidden="true"></div>
<% } %>

<main class="container-fluid px-lg-4 py-4">
    <section class="dashboard-heading">
        <div>
            <span class="eyebrow">Theo dõi sự kiện định kỳ</span>
            <h1>Sự kiện trong tháng <%= thang %></h1>
            <p>Danh sách tự động chuyển theo tháng hệ thống. Cập nhật đến ngày <span id="dashboardDate"></span>.</p>
        </div>
        <a class="btn btn-agribank" href="/khach-hang">
            <i class="fa-solid fa-arrow-up-right-from-square me-2"></i>Mở danh sách VIP
        </a>
    </section>

    <div class="monthly-grid">
        <section class="dashboard-panel">
            <header class="panel-header">
                <div>
                    <span class="eyebrow">Doanh nghiệp</span>
                    <h2>Ngày thành lập trong tháng <%= thang %></h2>
                </div>
                <span class="panel-count"><%= totalKhachHang %> doanh nghiệp</span>
            </header>
            <div class="monthly-list">
                <% if (danhSachKhachHang.length === 0) { %>
                    <div class="empty-state">
                        <i class="fa-regular fa-calendar-check"></i>
                        Không có doanh nghiệp kỷ niệm ngày thành lập trong tháng này.
                    </div>
                <% } %>
                <% danhSachKhachHang.forEach(item => { %>
                    <article class="monthly-item <%= item.la_hom_nay ? 'today' : '' %>">
                        <div class="event-date">
                            <strong><%= new Date(item.ngay_thanh_lap).getDate() %></strong>
                            <span>Tháng <%= thang %></span>
                        </div>
                        <div class="event-info">
                            <strong><%= item.ten_khach_hang %></strong>
                            <span>Ngày thành lập: <%= new Date(item.ngay_thanh_lap).toLocaleDateString('vi-VN') %></span>
                            <span>Cán bộ chăm sóc: <%= item.can_bo_cham_soc || '---' %></span>
                            <span>Phòng ban: <%= item.phong_ban || '---' %></span>
                            <% if (item.la_hom_nay) { %><small>Hôm nay</small><% } %>
                        </div>
                    </article>
                <% }) %>
            </div>
            <% if (tongTrangKhachHang > 1) { %>
                <nav class="panel-pagination" aria-label="Phân trang doanh nghiệp">
                    <a class="page-button <%= khPage <= 1 ? 'disabled' : '' %>"
                       href="<%= khPage <= 1 ? '#' : dashboardUrl(khPage - 1, vipPage) %>">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                    <span>Trang <strong><%= khPage %></strong>/<%= tongTrangKhachHang %></span>
                    <a class="page-button <%= khPage >= tongTrangKhachHang ? 'disabled' : '' %>"
                       href="<%= khPage >= tongTrangKhachHang ? '#' : dashboardUrl(khPage + 1, vipPage) %>">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </nav>
            <% } %>
        </section>

        <section class="dashboard-panel">
            <header class="panel-header">
                <div>
                    <span class="eyebrow">Khách hàng VIP</span>
                    <h2>Sinh nhật trong tháng <%= thang %></h2>
                </div>
                <span class="panel-count"><%= totalVip %> VIP</span>
            </header>
            <div class="monthly-list">
                <% if (danhSachVip.length === 0) { %>
                    <div class="empty-state">
                        <i class="fa-regular fa-calendar-check"></i>
                        Không có khách hàng VIP sinh nhật trong tháng này.
                    </div>
                <% } %>
                <% danhSachVip.forEach(item => { %>
                    <article class="monthly-item <%= item.la_hom_nay ? 'today' : '' %>">
                        <div class="event-date vip">
                            <strong><%= new Date(item.ngay_sinh).getDate() %></strong>
                            <span>Tháng <%= thang %></span>
                        </div>
                        <div class="event-info">
                            <strong><%= item.ho_ten %></strong>
                            <span><%= item.ten_chuc_vu || 'Chưa cập nhật chức vụ' %> · <%= item.ten_khach_hang || 'Chưa có doanh nghiệp' %></span>
                            <span>Sinh nhật: <%= new Date(item.ngay_sinh).toLocaleDateString('vi-VN') %><% if (item.so_dien_thoai) { %> · <%= item.so_dien_thoai %><% } %></span>
                            <% if (item.la_hom_nay) { %><small>Chúc mừng sinh nhật hôm nay</small><% } %>
                        </div>
                    </article>
                <% }) %>
            </div>
            <% if (tongTrangVip > 1) { %>
                <nav class="panel-pagination" aria-label="Phân trang VIP">
                    <a class="page-button <%= vipPage <= 1 ? 'disabled' : '' %>"
                       href="<%= vipPage <= 1 ? '#' : dashboardUrl(khPage, vipPage - 1) %>">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                    <span>Trang <strong><%= vipPage %></strong>/<%= tongTrangVip %></span>
                    <a class="page-button <%= vipPage >= tongTrangVip ? 'disabled' : '' %>"
                       href="<%= vipPage >= tongTrangVip ? '#' : dashboardUrl(khPage, vipPage + 1) %>">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </nav>
            <% } %>
        </section>
    </div>

    <div class="dashboard-options">
        <label for="dashboardLimit">Số dòng mỗi danh sách</label>
        <select id="dashboardLimit" class="form-select form-select-sm">
            <option value="20" <%= limit === 20 ? 'selected' : '' %>>20</option>
            <option value="50" <%= limit === 50 ? 'selected' : '' %>>50</option>
        </select>
    </div>
</main>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>
