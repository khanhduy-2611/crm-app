<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý tài khoản | CRM Agribank</title>
    <link href="/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/fontawesome/css/all.min.css" rel="stylesheet">
    <link href="/vendor/be-vietnam-pro/local.css" rel="stylesheet">
    <style>
        :root { --primary:#8c1d40; --accent:#d4af37; --bg:#f4f6f9; --text:#202737; }
        * { font-family:"Be Vietnam Pro",sans-serif; }
        body { background:var(--bg); color:var(--text); font-size:.88rem; }
        .navbar { background:var(--primary); border-bottom:3px solid var(--accent); }
        .navbar-brand,.nav-link { color:#fff!important; }
        .nav-link { opacity:.78; border-radius:7px; font-size:.8rem; font-weight:600; }
        .nav-link:hover,.nav-link.active { opacity:1; background:rgba(255,255,255,.14); }
        .card-panel { background:#fff; border:1px solid #e4e8ef; border-radius:14px; box-shadow:0 6px 18px rgba(28,38,58,.06); }
        .page-title { color:var(--primary); font-weight:800; font-size:1.35rem; }
        .form-label { font-size:.74rem; font-weight:700; color:#657084; }
        .btn-primary { --bs-btn-bg:var(--primary); --bs-btn-border-color:var(--primary); }
        .role-badge { padding:.32rem .55rem; border-radius:999px; font-size:.7rem; font-weight:700; }
        .role-admin { background:#f5dce5; color:var(--primary); }
        .role-truong_phong { background:#fff1c4; color:#7c5c00; }
        .role-can_bo { background:#dcefe8; color:#176747; }
        .user-box { color:#fff; font-size:.72rem; line-height:1.3; }
        @media(max-width:991px) { .navbar-nav { flex-direction:row; flex-wrap:wrap; } }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg py-2">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold" href="/"><i class="fa-solid fa-building-columns me-2" style="color:var(--accent)"></i>HỆ THỐNG CRM NỘI BỘ</a>
        <div class="navbar-nav ms-lg-3">
            <a class="nav-link" href="/">Dashboard</a>
            <a class="nav-link" href="/khach-hang">Khách hàng</a>
            <a class="nav-link active" href="/users">Quản lý tài khoản</a>
        </div>
    </div>
</nav>

<main class="container-fluid px-4 py-4">
    <div class="mb-4">
        <h1 class="page-title mb-1"><i class="fa-solid fa-users-gear me-2"></i>Quản lý tài khoản</h1>
        <div class="text-secondary">Tạo tài khoản và gán phạm vi dữ liệu cho cán bộ quản lý.</div>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <div class="row g-4">
        <div class="col-xl-4">
            <section class="card-panel p-4">
                <h2 class="h6 fw-bold mb-3">Tạo tài khoản</h2>
                <form action="/users" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Tên đăng nhập</label>
                        <input class="form-control" name="username" minlength="3" maxlength="50" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Họ tên</label>
                        <input class="form-control" name="full_name" maxlength="100">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu ban đầu</label>
                        <input class="form-control" type="password" name="password" minlength="8" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vai trò</label>
                        <select class="form-select" name="role" id="roleSelect" required>
                            <option value="can_bo">Cán bộ</option>
                            <option value="truong_phong">Trưởng phòng</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                    <div class="mb-3" id="officerField">
                        <label class="form-label">Cán bộ quản lý được liên kết</label>
                        <select class="form-select" name="can_bo_quan_ly_id" id="officerSelect">
                            <option value="">Tạo hồ sơ mới từ họ tên phía trên</option>
                            <% listCanBo.forEach(canBo => { %>
                                <option value="<%= canBo.id %>"><%= canBo.ho_ten %><%= canBo.phong_ban ? ' - ' + canBo.phong_ban : '' %></option>
                            <% }) %>
                        </select>
                        <div class="form-text">Nếu chưa có hồ sơ, để trống lựa chọn và nhập thông tin bên dưới.</div>
                        <div class="row g-2 mt-1">
                            <div class="col-md-6"><input class="form-control form-control-sm" name="phong_ban" placeholder="Phòng ban"></div>
                            <div class="col-md-6"><input class="form-control form-control-sm" name="so_dien_thoai" placeholder="Số điện thoại"></div>
                            <div class="col-12"><input class="form-control form-control-sm" type="email" name="email" placeholder="Email"></div>
                        </div>
                    </div>
                    <button class="btn btn-primary w-100 fw-bold" type="submit">Tạo tài khoản</button>
                </form>
            </section>
        </div>

        <div class="col-xl-8">
            <section class="card-panel p-3">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Tài khoản</th>
                                <th>Vai trò</th>
                                <th>Cán bộ liên kết</th>
                                <th>Ngày tạo</th>
                                <th style="min-width:230px">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                        <% users.forEach(account => { %>
                            <tr>
                                <td><strong><%= account.full_name || account.username %></strong><br><small class="text-secondary">@<%= account.username %></small></td>
                                <td><span class="role-badge role-<%= account.role %>"><%= account.role %></span></td>
                                <td><%= account.can_bo_quan_ly || '---' %></td>
                                <td><%= new Date(account.created_at).toLocaleDateString('vi-VN') %></td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <form class="d-flex gap-1" action="/users/<%= account.id %>/password" method="POST">
                                            <input class="form-control form-control-sm" type="password" name="password" minlength="8" placeholder="Mật khẩu mới" required>
                                            <button class="btn btn-sm btn-outline-warning" type="submit" title="Đặt lại mật khẩu"><i class="fa-solid fa-key"></i></button>
                                        </form>
                                        <form action="/users/<%= account.id %>/delete" method="POST" onsubmit="return confirm('Xóa tài khoản này?')">
                                            <button class="btn btn-sm btn-outline-danger" type="submit"><i class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
</main>

<script>
    const roleSelect = document.getElementById('roleSelect');
    const officerField = document.getElementById('officerField');
    const officerSelect = document.getElementById('officerSelect');
    function syncOfficerField() {
        const isOfficer = roleSelect.value === 'can_bo';
        officerField.style.display = isOfficer ? '' : 'none';
        officerSelect.required = isOfficer;
        if (!isOfficer) officerSelect.value = '';
    }
    roleSelect.addEventListener('change', syncOfficerField);
    syncOfficerField();
</script>
</body>
</html>
